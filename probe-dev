#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ./probe-dev <command> [args...]

Commands:
  fmt                      Run cargo fmt across the workspace.
  fmt-check                Check formatting without rewriting files.
  check                    Run cargo check across the workspace.
  test [cargo-test-args]   Prefer cargo nextest; fall back to cargo test.
  cli-regressions          Run the dedicated probe-cli regression and snapshot test binary.
  tui [args...]            Run the current Probe terminal UI.
  pr-fast                  Run the fast local merge-safe tier: fmt-check, check, and test.
  accept [args...]         Backward-compatible alias for accept-live.
  accept-live [args...]    Run the live acceptance harness against the configured backend.
  self-test [args...]      Run the retained Probe self-test harness lane.
  accept-compare [args...] Run the admitted-Mac Apple FM vs Qwen comparison lane.
  matrix [args...]         Run the heavier scenario-matrix lane with worst-of-N retention.
  decision-export [args...]  Run probe export with any extra CLI args.
  module-eval [args...]      Run probe module-eval with any extra CLI args.
  optimize-modules [args...] Run probe optimize-modules with any extra CLI args.
  optimize-harness [args...] Run probe optimize-harness with any extra CLI args.
EOF
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: missing required command: $1" >&2
    exit 1
  fi
}

command_name="${1:-}"
if [[ -z "$command_name" ]]; then
  usage
  exit 1
fi
shift

require_command cargo

case "$command_name" in
  fmt)
    cargo fmt --all
    ;;
  fmt-check)
    cargo fmt --all --check
    ;;
  check)
    cargo check --workspace
    ;;
  test)
    if cargo nextest --version >/dev/null 2>&1; then
      cargo nextest run --no-fail-fast "$@"
    else
      cargo test --workspace "$@"
    fi
    ;;
  cli-regressions)
    cargo test -p probe-cli --test cli_regressions "$@"
    ;;
  tui)
    cargo run -p probe-cli -- tui "$@"
    ;;
  pr-fast)
    "$0" fmt-check
    "$0" check
    "$0" test
    ;;
  accept|accept-live)
    cargo run -p probe-cli -- accept "$@"
    ;;
  self-test)
    cargo run -p probe-cli -- self-test "$@"
    ;;
  accept-compare)
    cargo run -p probe-cli -- accept-compare "$@"
    ;;
  matrix)
    cargo run -p probe-cli -- matrix "$@"
    ;;
  decision-export)
    cargo run -p probe-cli -- export "$@"
    ;;
  module-eval)
    cargo run -p probe-cli -- module-eval "$@"
    ;;
  optimize-modules)
    cargo run -p probe-cli -- optimize-modules "$@"
    ;;
  optimize-harness)
    cargo run -p probe-cli -- optimize-harness "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "error: unknown command: $command_name" >&2
    usage
    exit 1
    ;;
esac
