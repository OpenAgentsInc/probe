# Probe Forge worker environment
HOME=/var/lib/probe-worker
PROBE_HOME=/var/lib/probe-worker
PROBE_BINARY=/usr/local/bin/probe

# Forge control-plane scope
PROBE_FORGE_BASE_URL=
PROBE_FORGE_WORKER_ID=

# One-time bootstrap credential for the initial attach or a later refresh.
# After the worker has attached and `PROBE_HOME/auth/forge-worker.json` exists,
# this can be blank until you intentionally rotate and reattach.
PROBE_FORGE_BOOTSTRAP_TOKEN=

# Preferred first lane
PROBE_FORGE_PROFILE=openai-codex-subscription
PROBE_FORGE_WORKSPACE_ROOT=/var/lib/probe-worker/workspaces/default
PROBE_FORGE_POLL_INTERVAL_MS=1000

# Local smoke or bounded operator drills only
PROBE_FORGE_EXIT_ON_IDLE=false
PROBE_FORGE_MAX_ITERATIONS=

# Optional server arguments for non-Codex or non-hosted profiles
PROBE_FORGE_SERVER_MODE=attach
PROBE_FORGE_SERVER_HOST=
PROBE_FORGE_SERVER_PORT=
PROBE_FORGE_SERVER_MODEL_ID=
PROBE_FORGE_SERVER_MODEL_PATH=

# Optional hostname or attach metadata override
PROBE_FORGE_HOSTNAME_OVERRIDE=
PROBE_FORGE_ATTACHMENT_METADATA_JSON=

# Leave empty for `openai-codex-subscription`.
# Only set this when you intentionally run an env-backed OpenAI-compatible lane.
PROBE_OPENAI_API_KEY=
